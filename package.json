  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250609.0",
    "@types/bun": "latest",
    "typescript": "^6.0.3",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "posthog-node": "5.36.17"
  }
}
